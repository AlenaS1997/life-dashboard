# Шаблон переменных окружения. Скопируй в .env и заполни свои значения.
# Файл .env закоммичен НЕ будет (он в .gitignore).

GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password

GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_PATH=.secrets/service-account.json

GARMIN_WORKSHEET_NAME=Garmin

# FatSecret API (заполнить когда зарегистрируешься на platform.fatsecret.com).
# User-токен после авторизации сохраняется отдельно в .secrets/fatsecret_token.json
# (см. scripts/fatsecret_auth.py).
FATSECRET_CONSUMER_KEY=your_fatsecret_consumer_key
FATSECRET_CONSUMER_SECRET=your_fatsecret_consumer_secret
